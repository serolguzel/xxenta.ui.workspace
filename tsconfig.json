      "path": "./projects/xxenta.tenant.ui/tsconfig.app.json"
    },
    {
      "path": "./projects/xxenta.tenant.ui/tsconfig.spec.json"
    },
    {
      "path": "./projects/genesis-shell/tsconfig.lib.json"
    },
    {
      "path": "./projects/genesis-shell/tsconfig.spec.json"
    },
    {
      "path": "./projects/genesis-shell/tsconfig.lib.json"
    },
    {
      "path": "./projects/genesis-shell/tsconfig.spec.json"
    }
  ]
